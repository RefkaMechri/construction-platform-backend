// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
//************************************************************/
//*            USER                                          */
//************************************************************/
model User {
  id        Int   @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  role      Role
  tenantId   Int?
  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  status    String   @default("ACTIVE")  
  resetPasswordTokenHash   String?
  resetPasswordExpiresAt   DateTime?
  projects  Project[]
  equipments Equipment[] 
  materieaux  Material[] @relation("MaterialCreatedBy")
  createdEmployees Employee[] @relation("EmployeeCreatedBy")

  @@map("users")
}
enum Role {
  SUPER_ADMIN
  ADMIN
  DIRECTEUR
  PROJECT_MANAGER
  CONDUCTEUR_DE_TRAVAUX
  RESOURCE_MANAGER
  BUDGET_MANAGER
}

//************************************************************/
//*            TENANT                                        */
//************************************************************/

model Tenant {
  id        Int          @id @default(autoincrement())
  name      String
  slug      String       @unique
  email     String?      @unique //  optionnel (contact entreprise)
  phone     String?
  country   String?
  address   String?
  plan      TenantPlan   @default(Basic)
  status    TenantStatus @default(ACTIVE)
  modules   String[]     @default([])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users     User[]
  projects  Project[]
  employees Employee[]
  emquipements Equipment[] 
  materieaux   Material[] 

  @@map("tenants")
}

enum TenantPlan {
  Basic
  Pro
  Enterprise
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

model SubscriptionPlan {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  price      Float
  period     String   @default("/mois")
  icon       String   @default("box")
  isPopular  Boolean  @default(false)

  usersLimit    String
  projectsLimit String
  storageLimit  String
  supportType   String

  features   String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model featureModule {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  description  String
  icon         String   @default("box")
  category     String?
  isBaseModule Boolean  @default(false)

  starterEnabled      Boolean @default(false)
  professionalEnabled Boolean @default(false)
  enterpriseEnabled   Boolean @default(false)

  features     String[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

//************************************************************/
//*            PROJET                                        */
//************************************************************/

enum ProjectStatus {
  BROUILLON
  EN_COURS
  EN_PAUSE
  TERMINE
  ANNULE
}

enum ProjectType {
  RESIDENTIEL
  COMMERCIAL
  INFRASTRUCTURE
  INDUSTRIEL
  AUTRE
}
model Project {
  id               Int           @id @default(autoincrement())
  name             String
  code             String        @unique
  client           String
  address          String
  startDate        DateTime
  endDate          DateTime
  budget           Decimal       @db.Decimal(15, 2)
  description      String?
  status           ProjectStatus @default(BROUILLON)
  type             ProjectType

  // Le créateur = chef de projet
  projectManagerId Int
  projectManager   User          @relation(fields: [projectManagerId], references: [id])

  tenantId         Int
  tenant           Tenant        @relation(fields: [tenantId], references: [id])

  phases           Phase[]
  milestones       Milestone[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([tenantId])
  @@index([projectManagerId])
  @@index([status])
  @@index([type])
  @@map("projects")
}

//************************************************************/
//*            PHASES                                        */
//************************************************************/

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  OVERDUE
}
model Phase {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      PhaseStatus @default(NOT_STARTED)
  order       Int?

  projectId   Int
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks       Task[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
  @@index([status])
  @@map("phases")
}


//************************************************************/ 
//*             TASKS                                        */
//************************************************************/
enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  OVERDUE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  status        TaskStatus      @default(TODO)
  priority      TaskPriority    @default(MEDIUM)
  order         Int?

  phaseId       Int
  phase         Phase           @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  parentTaskId  Int?
  parentTask              Task?           @relation("TaskToSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks                Task[]          @relation("TaskToSubtasks")

  milestoneId             Int?
  milestone               Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignments             EmployeeAssignment[]
  assignmentsEq           EquipmentAssignment []
  assignmentsMt           MaterialAssignment []



  predecessors  TaskDependency[] @relation("DependencySuccessor")
  successors    TaskDependency[] @relation("DependencyPredecessor")

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([phaseId])
  @@index([parentTaskId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

//************************************************************/
//*             Milestone                                    */
//************************************************************/

enum MilestoneStatus {
  UPCOMING
  READY_FOR_VALIDATION
  ACHIEVED
  DELAYED
  CANCELLED
}

model Milestone {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  dueDate     DateTime
  achievedAt  DateTime?
  status      MilestoneStatus @default(UPCOMING)

  projectId   Int
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks       Task[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@map("milestones")
}


//************************************************************/
//*             Task Dependency                              */
//************************************************************/

enum TaskDependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

model TaskDependency {
  id                Int                @id @default(autoincrement())

  predecessorTaskId Int
  successorTaskId   Int
  type              TaskDependencyType @default(FINISH_TO_START)
  lagDays           Int                @default(0)

  predecessorTask   Task               @relation("DependencyPredecessor", fields: [predecessorTaskId], references: [id], onDelete: Cascade)
  successorTask     Task               @relation("DependencySuccessor", fields: [successorTaskId], references: [id], onDelete: Cascade)

  createdAt         DateTime           @default(now())

  @@unique([predecessorTaskId, successorTaskId])
  @@index([predecessorTaskId])
  @@index([successorTaskId])
  @@map("task_dependencies")
}
//************************************************************/
//*                    Employee                              */
//************************************************************/
model Employee {
  id           Int      @id @default(autoincrement())
  name         String
  email        String?
  phone        String?

  jobTitle     String
  skills       String[]

  availabilityStatus String @default("AVAILABLE")

  status       String   @default("ACTIVE")
  assignments EmployeeAssignment[]


  tenantId     Int
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  createdById        Int?
  createdBy          User?    @relation("EmployeeCreatedBy", fields: [createdById], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
//************************************************************/
//*                    Equipement                            */
//************************************************************/

model Equipment {
  id                 Int      @id @default(autoincrement())
  name               String
  code               String?  @unique
  description        String?

  category           String
  brand              String?
  model              String?
  serialNumber       String?
  yearOfManufacture  Int?

  quantity           Int      @default(1)
  unit               String?  // piece, unit, ton...
  capacity           String?  // 5 tons, 1000kg...

  status             String   @default("ACTIVE")
  availabilityStatus String   @default("AVAILABLE")
  condition          String?  // NEW, GOOD, FAIR, DAMAGED
  assignments         EquipmentAssignment[]

  ownershipType      String?  // OWNED, RENTED, LEASED
  purchaseDate       DateTime?

  tenantId           Int
  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  createdById        Int?
  createdBy          User?    @relation(fields: [createdById], references: [id])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

//************************************************************/
//*                    Material                             */
//************************************************************/

model Material {
  id               Int      @id @default(autoincrement())
  name             String
  code             String?  @unique
  description      String?

  category         String   // Cement, Sand, Steel, Wood...
  brand            String?

  quantity         Float    @default(0)
  reservedQuantity   Float    @default(0) // quantité réservée pour les tâches
  unit             String   // kg, ton, m3, piece, bag...

  quality          String?  // HIGH, MEDIUM, LOW
  status           String   @default("ASSIGNED") // ASSIGNED, USED, CANCELLED
  availabilityStatus String   @default("AVAILABLE")

  notes            String?

  tenantId         Int
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  assignments         MaterialAssignment[]

  createdById      Int?
  createdBy        User?    @relation("MaterialCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


model EmployeeAssignment {
  id          Int       @id @default(autoincrement())

  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])

  taskId      Int
  task        Task      @relation(fields: [taskId], references: [id])

  startDate   DateTime
  endDate     DateTime

  notes       String?

  createdById Int?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
model EquipmentAssignment {
  id           Int        @id @default(autoincrement())

  equipmentId  Int
  equipment    Equipment  @relation(fields: [equipmentId], references: [id])

  taskId       Int
  task         Task       @relation(fields: [taskId], references: [id])

  startDate    DateTime
  endDate      DateTime

  notes        String?

  createdById  Int?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MaterialAssignment {
  id          Int       @id @default(autoincrement())

  materialId  Int
  material    Material  @relation(fields: [materialId], references: [id])

  taskId      Int
  task        Task      @relation(fields: [taskId], references: [id])

  quantity    Float

  notes       String?
  startDate   DateTime
  status      String    @default("RESERVED")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}